# vim: ft=bash
_env_cmd brew || return

alias brew-requested="brew leaves -r && echo && brew list --cask -1"

brew-usage() {
    brew list --formula | xargs -n1 -P8 -I {} \
        sh -c "brew info {} | \
            egrep '[0-9]* files, ' | \
            sed 's/^.*[0-9]* files, \(.*\)).*$/{} \1/'" |
        sort -h -r -k2 - | column -t
}
