# vim: ft=bash
_env_cmd chezmoi || return
[ -d "$(chezmoi source-path)" ] || return

# echo chezmoi state
if [ -z "$TMUX" ]; then
    _verify=$(chezmoi verify --exclude=scripts >/dev/null 2>&1 || echo "drift (inspect with 'cz state') ")
    _uncommitted=$(chezmoi git status -- --porcelain 2>/dev/null | grep -q . && echo "uncommitted " || :)
    _unpushed=$(chezmoi git log -- --branches --not --remotes --oneline 2>/dev/null | grep -q . && echo "unpushed" || :)

    [ -n "${_verify}${_uncommitted}${_unpushed}" ] && \
      printf "\033[33mchezmoi: %s%s%s\033[0m\n" "$_verify" "$_uncommitted" "$_unpushed"
    unset _verify _uncommitted _unpushed
fi

unset -f czup 2>/dev/null

cz() {
    case "${1-}" in
        state)
            chezmoi status --exclude=scripts; chezmoi git -- status -s
            ;;
        up)
            chezmoi update && resrc
            ;;
        ap)
            chezmoi apply && resrc
            ;;
        ssh)
            shift 1
            chezmoi ssh "$@"
            ;;
        edit)
            shift 1
            chezmoi edit --apply "$@"
            ;;
        diff)
            shift 1
            chezmoi diff --exclude=scripts "$@"
            ;;
        save)
            printf 'Saving chezmoi changes to git...\n\n'
            if chezmoi git -- diff --cached --quiet 2>/dev/null; then
                printf 'No staged changes to commit.\n'
                chezmoi git -- status -s
                if ! chezmoi git -- diff --quiet 2>/dev/null || \
                   chezmoi git -- ls-files --others --exclude-standard | grep -q .; then
                    printf "\nStage intended paths with 'cz add <target>' before saving.\n"
                    return 1
                fi
            else
                printf 'Changes:\n'
                chezmoi git -- status -s
                sleep 2.5
                printf '\n'
                chezmoi git -- commit -m "${*:-$(chezmoi git -- status -s)}" -m "$(hostname -s)" || return
            fi

            chezmoi git log -- --branches --not --remotes --oneline 2>/dev/null | grep -q . || {
                printf 'No unpushed commits\n'
                return 0
            }

            chezmoi git -- pull --rebase && chezmoi git push
            printf 'Chezmoi saved to git\n'
            ;;
        add)
            shift 1
            if [ "$#" -lt 1 ]; then
                chezmoi re-add --interactive && chezmoi git add -u .
            else
                for f in "$@"; do
                    if chezmoi source-path "$f" >/dev/null 2>&1; then
                        chezmoi re-add "$f"
                    else
                        echo "add file $f"
                        chezmoi add "$f"
                    fi
                    chezmoi git add -- "$(chezmoi source-path "$f")"
                done
            fi
            ;;
        *) chezmoi "$@"
            ;;
    esac
}

alias sshconfig="cz edit ~/.ssh/config && resrc"

_env_shell zsh && {
    _cz_completion() {
        local -a subcmds=('state' 'up' 'ap' 'save' 'ssh' 'edit' 'diff' 'add')
        local -a path_subcmds=('edit' 'diff' 'add')
        local cur first

        cur=${words[CURRENT]}
        first=${words[2]}

        if (( CURRENT == 2 )); then
            _describe -t subcommands 'cz subcommand' subcmds
            return
        fi

        if (( ${path_subcmds[(Ie)$first]} )); then
            _files
        fi
        return
    }
    compdef _cz_completion cz
}

_env_shell bash && {
    . <(chezmoi completion bash --)

    _cz_completion() {
        local words="state up ap save ssh"
        local words_path="edit diff add"
        local cur first
        COMPREPLY=()

        cur="${COMP_WORDS[COMP_CWORD]}"
        first="${COMP_WORDS[1]}"

        # position 1 after command: suggest all keywords
        if (( COMP_CWORD == 1 )); then
            local opts="$words $words_path"
            COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
            return 0
        fi

        for w in $words_path; do
            if [[ $first == "$w" ]]; then
                compopt -o bashdefault -o default 2>/dev/null
            fi
        done
        return 0
    }
    complete -F _cz_completion cz
}
