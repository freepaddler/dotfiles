# vim: ft=bash
_env_cmd docker || return

alias drm="docker run --rm"
alias dps='docker ps --format "table {{.Names}}\\t{{.RunningFor}}\\t{{.Status}}\\t{{.Image}}"'
alias dcomp="docker compose"
alias docit="docker exec -it"

_env_shell zsh && {
    _docker_lazy() {
        unfunction _docker_lazy
        . <(docker completion zsh)
        zle .complete-word
    }
    compdef _docker_lazy docker
}

_env_shell bash && {
    _docker_lazy() {
        unset -f _docker_lazy
        complete -r docker
        . <(docker completion bash)
        if declare -F __start_docker >/dev/null; then
            __start_docker
        fi
    }
    complete -o default -F _docker_lazy docker
}
